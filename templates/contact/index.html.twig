{% extends 'base.html.twig' %}

{% block title %}Contact - EcoRadar{% endblock %}

{% block body %}
<div class="container py-5" style="font-family: 'Poppins', sans-serif;">
  <h1 class="text-center mb-5 fw-bold" style="background-color: #f4b860; display: inline-block; padding: 10px 30px; border-radius: 20px;">
    Contactez-nous
  </h1>

  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="p-4 shadow rounded" style="background-color: #fff;">
        {{ form_start(form) }}

        <div class="mb-3">
          {{ form_label(form.firstName) }}
          {{ form_widget(form.firstName, {'attr': {'class': 'form-control rounded-pill'}}) }}
        </div>
        <div class="mb-3">
          {{ form_label(form.lastName) }}
          {{ form_widget(form.lastName, {'attr': {'class': 'form-control rounded-pill'}}) }}
        </div>
        <div class="mb-3">
          {{ form_label(form.email) }}
          {{ form_widget(form.email, {'attr': {'class': 'form-control rounded-pill'}}) }}
        </div>
        <div class="mb-3">
          {{ form_label(form.message) }}
          {{ form_widget(form.message, {'attr': {'class': 'form-control', 'rows': 5}}) }}
        </div>

        <div class="text-center">
         <button type="submit" class="btn px-4 py-2 rounded-pill"
  style="background-color: #f4b860; color: #000; font-weight: 600; border: none;">
  Envoyer
</button>

        </div>

        {{ form_end(form) }}
      </div>
    </div>
  </div>
</div>
{% endblock %}
