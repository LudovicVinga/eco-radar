{% extends 'base.html.twig' %}

{% block title %}Contactez-nous - EcoRadar{% endblock %}

{% block body %}
<section class="py-5" style="font-family: 'Poppins', sans-serif; background: #f8f9fa;">
  <div class="container">
    <h1 class="text-center mb-5 fw-bold text-dark">Contactez-nous</h1>

    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">
        <div class="card shadow rounded-4 p-4 border-0 bg-white">
          {{ form_start(form) }}

          <div class="mb-3">
            {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.firstName, {'attr': {'class': 'form-control rounded-3'}}) }}
          </div>

          <div class="mb-3">
            {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.lastName, {'attr': {'class': 'form-control rounded-3'}}) }}
          </div>

          <div class="mb-3">
            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'form-control rounded-3'}}) }}
          </div>

          <div class="mb-3">
            {{ form_label(form.message, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.message, {'attr': {'class': 'form-control rounded-3', 'rows': 5}}) }}
          </div>

          <div class="text-center">
            <button type="submit" class="btn btn-warning px-4 py-2 rounded-pill fw-semibold">Envoyer</button>
          </div>

          <div class="text-center mt-3">
          <a href="{{ path('homepage') }}" class="text-decoration-none text-muted">
         ← Retour à l'accueil
       </a>
        </div>

          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
