{% extends 'base.html.twig' %}

{% block title %}Accueil - EcoRadar{% endblock %}

{% block body %}
<section class="hero-header text-white text-center d-flex align-items-center justify-content-center shadow-lg rounded-4 overflow-hidden" style="
    background: linear-gradient(rgba(44, 62, 80, 0.85), rgba(44, 62, 80, 0.85)), 
                url('{{ asset('images/header-fashion.jpg') }}') center/cover no-repeat;
    min-height: 90vh;
    font-family: 'Poppins', sans-serif;
">
  <div class="container">
    <h1 class="display-4 fw-bold animate__animated animate__fadeInDown">Repérez les labels<br>de mode éthique</h1>
    <p class="lead mt-3 animate__animated animate__fadeInUp animate__delay-1s">
      Découvrez les certifications du monde entier<br>et <strong>soutenez une mode responsable</strong>.
    </p>
    <a href="{{ path('explorer') }}" class="btn btn-lg mt-4 px-4 py-2 animate__animated animate__fadeInUp animate__delay-2s" style="
      background-color:  b #F4B860; 
      color: #333333; 
      font-weight: 600;
      border-radius: 50px;
      transition: background-color 0.3s ease;">
      Découvrir les labels
    </a>
  </div>
</section>

<section class="py-5 bg-white">
  <div class="container">
    <h2 class="text-center mb-4" style="font-family: 'Poppins', sans-serif;">Pourquoi EcoRadar ?</h2>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card why-card h-100 text-center border-0 shadow-sm p-3">
          <div class="card-body">
            <i class="bi bi-globe mb-3" style="font-size: 2rem; color: #6f42c1;"></i>
            <h5 class="card-title">Transparence mondiale</h5>
            <p class="card-text text-muted">Accédez à une base de labels éthiques reconnus dans le monde entier.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card why-card h-100 text-center border-0 shadow-sm p-3">
          <div class="card-body">
            <i class="bi bi-bar-chart-line mb-3" style="font-size: 2rem; color: #6f42c1;"></i>
            <h5 class="card-title">Données interactives</h5>
            <p class="card-text text-muted">Explorez les données par secteur, pays ou certification.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card why-card h-100 text-center border-0 shadow-sm p-3">
          <div class="card-body">
            <i class="bi bi-people mb-3" style="font-size: 2rem; color: #6f42c1;"></i>
            <h5 class="card-title">Communauté engagée</h5>
            <p class="card-text text-muted">Une plateforme ouverte et collaborative pour tous les citoyens responsables.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>



{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
{% endblock %}
