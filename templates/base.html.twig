<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}EcoRadar{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
 
     <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600&display=swap" rel="stylesheet">

     <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
      
      <link rel="stylesheet" href="{{ asset('css/style.css') }}">

     
</head>
<body>
    <header>
 <nav id="mainNavbar"class="navbar navbar-expand-lg navbar-light bg-warning fixed-top shadow-sm rounded-bottom" style="background-color: #f4b860;">

  <div class="container-fluid">
    <a class="navbar-brand fw-bold text-warning d-flex align-items-center fs-4" href="{{ path('app_visitor_welcome') }}">
      <img src="/images/static/visitor/Logo_ecoRadar.jpg" alt="EcoRadar" width="48" class="rounded-circle me-3">
      
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fs-5">
        <li class="nav-item">
          <a class="nav-link" href="{{ path('a_propos') }}">À propos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('explorer') }}">Explorer les labels</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('visualisations') }}">Visualisations</a>
        </li>

        {% if app.user %}
          {% if is_granted('ROLE_ADMIN') %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_admin_home') }}">Espace admin</a>
          </li>
          {% endif %}
          {% if is_granted('ROLE_USER') %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_user_home') }}">Espace utilisateur</a>
          </li>
          {% endif %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
          </li>
        {% else %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_register') }}">Inscription</a>
          </li>
          <li class="nav-item">
        <a class="nav-link" href="{{ path('contact') }}">Contact</a>
       </li>
        {% endif %}
      </ul>
    </div>
  </div>
</nav>

    </header>

    <main class="container my-5">
        {% block body %}{% endblock %}
    </main>

  <footer class="text-white mt-5" style="background-color: #5a2ca0; border-top-left-radius: 30px; border-top-right-radius: 30px; overflow: hidden;">
  <div class="container py-4">
    <div class="row">
      <div class="col-md-6 mb-3">
        <h5 class="fw-bold">EcoRadar</h5>
        <p class="mb-0">Une plateforme dédiée à la transparence des labels éthiques dans le monde.</p>
      </div>
      <div class="col-md-6 text-md-end">
        <a href="{{ path('explorer') }}" class="btn btn-outline-light btn-sm me-2 mb-2">Explorer</a>
        <a href="{{ path('visualisations') }}" class="btn btn-outline-light btn-sm me-2 mb-2">Visualisations</a>
        <a href="{{ path('a_propos') }}" class="btn btn-outline-light btn-sm me-2 mb-2">À propos</a>
        <a href="{{ path('contact') }}" class="btn btn-outline-light btn-sm mb-2">Contact</a>
      </div>
    </div>
    <hr class="border-light">
    <div class="text-center small">
      © {{ "now"|date("Y") }} EcoRadar. Tous droits réservés.
    </div>
  </div>
</footer>



    {% block javascripts %}
    <script>
  window.addEventListener('scroll', function () {
    const navbar = document.getElementById('mainNavbar');
    if (window.scrollY > 50) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });
</script>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% endblock %}
</body>
</html>
