<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}EcoRadar{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
 
     <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600&display=swap" rel="stylesheet">

     <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
      
      <link rel="stylesheet" href="{{ asset('css/style.css') }}">

     
</head>
<body>
    <header>
 <nav id="mainNavbar" class="navbar navbar-expand-lg navbar-dark bg-dark rounded-bottom px-4 py-2 fixed-top shadow">

  <div class="container-fluid">
    <a class="navbar-brand fw-bold text-warning d-flex align-items-center fs-4" href="{{ path('app_visitor_welcome') }}">
      <img src="/images/static/visitor/Logo_ecoRadar.jpg" alt="EcoRadar" width="48" class="rounded-circle me-3">
      EcoRadar
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fs-5">
        <li class="nav-item">
          <a class="nav-link" href="{{ path('a_propos') }}">À propos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('explorer') }}">Explorer les labels</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('visualisations') }}">Visualisations</a>
        </li>

        {% if app.user %}
          {% if is_granted('ROLE_ADMIN') %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_admin_home') }}">Espace admin</a>
          </li>
          {% endif %}
          {% if is_granted('ROLE_USER') %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_user_home') }}">Espace utilisateur</a>
          </li>
          {% endif %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
          </li>
        {% else %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_register') }}">Inscription</a>
          </li>
        {% endif %}
      </ul>
    </div>
  </div>
</nav>

    </header>

    <main class="container my-5">
        {% block body %}{% endblock %}
    </main>

   <footer class="text-light py-5 mt-5" style="background-color: #7566D9; font-family: 'Poppins', sans-serif;">
  <div class="container">
    <div class="row justify-content-between align-items-center mb-4">
      <div class="col-md-6">
        <h5 class="fw-bold">EcoRadar</h5>
        <p class="small text-light">Une plateforme dédiée à la transparence des labels éthiques dans le monde.</p>
      </div>
      <div class="col-md-6 text-md-end">
        <a href="{{ path('explorer') }}" class="btn btn-outline-light me-2 mb-2">Explorer</a>
        <a href="{{ path('visualisations') }}" class="btn btn-outline-light me-2 mb-2">Visualisations</a>
        <a href="{{ path('a_propos') }}" class="btn btn-outline-light mb-2">À propos</a>
      </div>
    </div>

    <hr class="border-light">

    <div class="d-flex justify-content-between flex-column flex-md-row align-items-center small">
      <p class="mb-2 mb-md-0">© {{ "now"|date("Y") }} EcoRadar. Tous droits réservés.</p>
      <div class="d-flex gap-3">
        <a href="#" class="text-decoration-none text-light">Mentions légales</a>
        <a href="mailto:contact@ecoradar.org" class="text-decoration-none text-light">Contact</a>
        <a href="#" class="text-decoration-none text-light">Newsletter</a>
      </div>
    </div>
  </div>
</footer>


    {% block javascripts %}
    <script>
  window.addEventListener('scroll', function () {
    const navbar = document.getElementById('mainNavbar');
    if (window.scrollY > 50) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });
</script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% endblock %}
</body>
</html>
