{% extends 'base.html.twig' %}

{% block title %}À propos - EcoRadar{% endblock %}

{% block body %}
<div class="container py-5">
  <h2 class="text-center mb-4 animate__animated animate__fadeInDown">À propos d’EcoRadar</h2>

  <p class="lead text-center animate__animated animate__fadeInUp">
     EcoRadar est une plateforme collaborative dédiée à la découverte, la visualisation et la transparence des labels éthiques dans le monde entier.
  </p>

  <div class="row mt-5">
    <div class="col-md-6 animate__animated animate__fadeInLeft">
      <h4> Notre mission</h4>
      <p>
        Offrir un accès clair et interactif aux informations sur les labels éthiques afin d’aider les consommateurs, marques et chercheurs à faire des choix éclairés.
      </p>
    </div>

    <div class="col-md-6 animate__animated animate__fadeInRight">
      <h4> Fonctionnalités</h4>
      <ul class="list-unstyled">
        <li> Exploration des labels par pays et secteur</li>
        <li> Visualisation avec graphiques et cartes interactives</li>
        <li> Recherche filtrée (nom, secteur, certification)</li>
      </ul>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
{% endblock %}
